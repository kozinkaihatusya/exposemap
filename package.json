{
  "name": "exposemap",
  "version": "0.2.0",
  "description": "Open-source exposure mapper for self-hosted Docker Compose services",
  "type": "module",
  "bin": {
    "exposemap": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "scan:example": "node dist/cli.js scan examples/risky-compose.yml --format markdown"
  },
  "keywords": [
    "docker",
    "docker-compose",
    "self-hosted",
    "security",
    "homelab",
    "exposure"
  ],
  "author": "",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "commander": "^14.0.2",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": ">=20"
  }
}
